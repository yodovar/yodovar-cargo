# Локальная разработка: SQLite (файл появится после migrate)
DATABASE_URL="file:./dev.db"
NODE_ENV=development

# Продакшен: postgresql://user:pass@host:5432/yodovar?schema=public

# CORS для веб-админки. Пусто = разрешить любые origin (только для dev).
CORS_ORIGINS=

# Минимум ~32 символа в продакшене (openssl rand -base64 32)
JWT_SECRET="change-me-min-32-chars-please-use-openssl-rand"
JWT_REFRESH_SECRET="change-me-refresh-min-32-chars"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="30d"

# Dev: фиксированный 6-значный OTP вместо случайного (не использовать в production).
OTP_DEV_CODE=123456

PORT=3000

# Номер первого администратора (E.164 +992…). При старте создаётся/повышается до admin.
# Можно совпадать с STAFF_ADMIN_PHONE.
ADMIN_PHONE=

# Строка в QR до кода: yodovar-cargo://client/<clientCode>
CLIENT_QR_SCHEME_BASE=yodovar-cargo://client
