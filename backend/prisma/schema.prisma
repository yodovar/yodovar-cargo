generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  client
  worker_cn
  worker_tj
  admin
}

model User {
  id           String   @id @default(uuid())
  phone        String   @unique
  name         String
  passwordHash String
  role         UserRole @default(client)
  /// Уникальный код клиента (например SF3456). Для работников/админа тоже может быть заполнен.
  clientCode   String?  @unique
  createdAt    DateTime @default(now())
  orders       Order[]
}

/// Временная запись до подтверждения OTP (регистрация).
model PendingRegistration {
  id           String   @id @default(uuid())
  phone        String   @unique
  name         String
  passwordHash String
  otpHash      String
  expiresAt    DateTime
  createdAt    DateTime @default(now())
}


model PendingOtp {
  id        String   @id @default(uuid())
  phone     String   @unique
  otpHash   String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Tariff {
  id                String   @id @default(uuid())
  key               String   @unique
  title             String
  pricePerKgUsd     Float
  pricePerCubicUsd  Float
  minChargeWeightG  Int
  etaDaysMin        Int
  etaDaysMax        Int
  detailsJson       String
  updatedAt         DateTime @updatedAt
  createdAt         DateTime @default(now())
}

model SupportContact {
  id               String   @id @default(uuid())
  key              String   @unique
  label            String
  usernameOrPhone  String
  appUrl           String
  webUrl           String
  updatedAt        DateTime @updatedAt
  createdAt        DateTime @default(now())
}

model Order {
  id           String    @id @default(uuid())
  trackingCode String    @unique
  status       String
  isPaid       Boolean   @default(false)
  /// Владелец посылки (клиент), привязывается при приёмке на складе КНР.
  clientId     String?
  client       User?     @relation(fields: [clientId], references: [id], onDelete: SetNull)
  /// Вес брутто, граммы (фиксирует склад КНР).
  weightGrams  Int?
  /// Когда выдано клиенту на складе ТЖ.
  handedOverAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String?
  action     String
  entityType String
  entityId   String
  beforeJson String?
  afterJson  String?
  createdAt  DateTime @default(now())
}
